<controls:ProWindow x:Class="ProPilot.UI.SettingsWindow"
                     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:controls="clr-namespace:ArcGIS.Desktop.Framework.Controls;assembly=ArcGIS.Desktop.Framework"
                     Title="ProPilot - Settings"
                     Height="340" Width="420"
                     WindowStartupLocation="CenterOwner"
                     ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LLM Provider -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="LLM Provider:"
                   VerticalAlignment="Center" Margin="0,0,0,8"/>
        <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,8"
                  SelectedItem="{Binding LlmProvider}"
                  ItemsSource="{Binding AvailableProviders}"/>

        <!-- Ollama Endpoint -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Ollama Endpoint:"
                   VerticalAlignment="Center" Margin="0,0,0,8"/>
        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,8"
                 Text="{Binding OllamaEndpoint, UpdateSourceTrigger=PropertyChanged}"
                 Padding="4,2"/>

        <!-- Model Name -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Model Name:"
                   VerticalAlignment="Center" Margin="0,0,0,8"/>
        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,8"
                 Text="{Binding ModelName, UpdateSourceTrigger=PropertyChanged}"
                 Padding="4,2"/>

        <!-- Timeout -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Timeout (sec):"
                   VerticalAlignment="Center" Margin="0,0,0,8"/>
        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,8"
                 Text="{Binding TimeoutSeconds, UpdateSourceTrigger=PropertyChanged}"
                 Padding="4,2"/>

        <!-- Status Message -->
        <TextBlock Grid.Row="4" Grid.ColumnSpan="2"
                   Text="{Binding StatusMessage}"
                   VerticalAlignment="Bottom"
                   Margin="0,8,0,8"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource Esri_TextBrush}"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Test Connection"
                    Command="{Binding TestConnectionCommand}"
                    Padding="12,6" Margin="0,0,8,0"/>
            <Button Content="Save to Project"
                    Command="{Binding SaveToProjectCommand}"
                    Padding="12,6" Margin="0,0,8,0"
                    FontWeight="SemiBold"/>
            <Button Content="Save as Default"
                    Command="{Binding SaveToUserDefaultsCommand}"
                    Padding="12,6"/>
        </StackPanel>
    </Grid>
</controls:ProWindow>
