<controls:ProWindow x:Class="ProPilot.UI.SetupWindow"
                     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:controls="clr-namespace:ArcGIS.Desktop.Framework.Controls;assembly=ArcGIS.Desktop.Framework"
                     Title="ProPilot - First-Time Setup"
                     Height="480" Width="500"
                     WindowStartupLocation="CenterOwner"
                     ResizeMode="NoResize">
    <controls:ProWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </controls:ProWindow.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Welcome to ProPilot" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="ProPilot needs to download an AI model for local command parsing."
                       TextWrapping="Wrap" Margin="0,6,0,0" FontSize="12"/>
            <TextBlock Margin="0,4,0,0" FontSize="12">
                <Run Text="System RAM:"/>
                <Run Text="{Binding SystemRamGb, Mode=OneWay}" FontWeight="SemiBold"/>
                <Run Text="GB - Recommended:"/>
                <Run Text="{Binding RecommendedTier, Mode=OneWay}" FontWeight="SemiBold"/>
            </TextBlock>
        </StackPanel>

        <!-- Model Profiles List -->
        <ListBox Grid.Row="2"
                 ItemsSource="{Binding Profiles}"
                 SelectedItem="{Binding SelectedProfile}"
                 Margin="0,0,0,12">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10" Margin="2" CornerRadius="4"
                            BorderBrush="{DynamicResource Esri_BorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text=" ? Recommended" Foreground="Green" FontWeight="SemiBold"
                                           Visibility="{Binding IsRecommended, Converter={StaticResource BoolToVis}}"
                                           Margin="8,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap"
                                       Margin="0,4,0,2" FontSize="11"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding FileSizeText}" FontSize="11"
                                           Foreground="{DynamicResource Esri_TextBrush}" Margin="0,0,12,0"/>
                                <TextBlock Text="{Binding MinRamText}" FontSize="11"
                                           Foreground="{DynamicResource Esri_TextBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Download Progress -->
        <StackPanel Grid.Row="3" Margin="0,0,0,12"
                    Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
            <TextBlock Text="{Binding DownloadStatus}" FontSize="12" Margin="0,0,0,4"/>
            <ProgressBar Value="{Binding DownloadPercent}" Minimum="0" Maximum="100" Height="16"/>
            <TextBlock Text="{Binding BytesDownloadedText}" FontSize="11" Margin="0,4,0,0"
                       Foreground="{DynamicResource Esri_TextBrush}"/>
        </StackPanel>

        <!-- Error Message -->
        <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}"
                   Foreground="Red" TextWrapping="Wrap" FontSize="12"
                   Visibility="{Binding HasError, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Browse for Model..."
                    Command="{Binding BrowseForModelCommand}"
                    Padding="12,6" Margin="0,0,8,0"/>
            <Button Content="Cancel Download"
                    Command="{Binding CancelDownloadCommand}"
                    Padding="12,6" Margin="0,0,8,0"
                    Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"/>
            <Button Content="Download"
                    Command="{Binding DownloadModelCommand}"
                    Padding="16,6"
                    FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</controls:ProWindow>
