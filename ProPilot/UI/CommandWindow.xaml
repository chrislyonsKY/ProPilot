<controls:ProWindow x:Class="ProPilot.UI.CommandWindow"
                     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:controls="clr-namespace:ArcGIS.Desktop.Framework.Controls;assembly=ArcGIS.Desktop.Framework"
                     xmlns:local="clr-namespace:ProPilot.UI"
                     Title="ProPilot"
                     Height="520" Width="440"
                     MinHeight="400" MinWidth="360"
                     WindowStartupLocation="CenterOwner"
                     ResizeMode="CanResizeWithGrip">
    <controls:ProWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </controls:ProWindow.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Command Input -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding CommandInput, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}"
                     Padding="6,4" FontSize="13"
                     VerticalContentAlignment="Center">
                <TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding SubmitCommandCommand}"/>
                </TextBox.InputBindings>
            </TextBox>
            <Button Grid.Column="1" Content="Send"
                    Command="{Binding SubmitCommandCommand}"
                    Margin="6,0,0,0" Padding="12,4" FontSize="13"/>
            <Button Grid.Column="2" Content="&#x2699;"
                    Command="{Binding OpenSettingsCommand}"
                    ToolTip="Settings"
                    Margin="4,0,0,0" Padding="8,4" FontSize="13"/>
        </Grid>

        <!-- Preview Panel -->
        <Border Grid.Row="1" Margin="0,10,0,10"
                BorderBrush="{DynamicResource Esri_BorderBrush}"
                BorderThickness="1" CornerRadius="4" Padding="10"
                Visibility="{Binding HasPreview, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="{Binding CurrentPreview.Icon}"
                               FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentPreview.Title}"
                               FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Confidence:" FontWeight="SemiBold" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding ConfidenceText}"/>
                </StackPanel>
                <TextBlock Text="&#x26A0; This command modifies data"
                           Foreground="OrangeRed" FontWeight="SemiBold" Margin="0,0,0,6"
                           Visibility="{Binding CurrentPreview.IsDestructive, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"/>
                <ItemsControl ItemsSource="{Binding PreviewParameters}" Margin="0,0,0,10">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="{Binding Key}" FontWeight="SemiBold" Width="100"/>
                                <TextBlock Text="{Binding Value}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Execute" Command="{Binding ExecuteCommandCommand}"
                            Padding="16,6" Margin="0,0,6,0" FontWeight="SemiBold"/>
                    <Button Content="Cancel" Command="{Binding CancelCommandCommand}"
                            Padding="16,6"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Processing Indicator -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
            <TextBlock Text="Processing..." FontSize="14" HorizontalAlignment="Center"/>
            <ProgressBar IsIndeterminate="True" Height="4" Width="200" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Command History -->
        <Expander Grid.Row="2" Header="History" IsExpanded="False" Margin="0,0,0,6"
                  Visibility="{Binding HasHistory, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
            <ListBox ItemsSource="{Binding CommandHistory}"
                     MaxHeight="100" BorderThickness="0" FontSize="11"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>
        </Expander>

        <!-- Status Bar -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                       FontSize="11" VerticalAlignment="Center"
                       Foreground="{DynamicResource Esri_TextBrush}"
                       TextTrimming="CharacterEllipsis"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8" Margin="0,0,4,0"
                         Fill="{Binding ConnectionIndicatorColor, FallbackValue=Gray}"/>
                <TextBlock Text="{Binding ModelName}" FontSize="11"
                           Foreground="{DynamicResource Esri_TextBrush}"/>
            </StackPanel>
        </Grid>
    </Grid>
</controls:ProWindow>
